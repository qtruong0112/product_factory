  "x-semantic-relationship-mapping": {
    "description": "Ánh xạ 29 relationships trong sheet '3. Relationships' sang hiện thực hóa relational",
    "map": [
      { "rel": 1,  "semantic": "ElementType classifies Element 1:N",            "implementation": "obligation_element.element_type_code FK" },
      { "rel": 2,  "semantic": "Element composes Type N:1 (đúng 1/OET)",        "implementation": "obligation_type_composition, PK(type,element_type)" },
      { "rel": 3,  "semantic": "Nature identifies Family 1:1",                  "implementation": "obligation_family.identified_by_nature_code FK UNIQUE" },
      { "rel": 4,  "semantic": "Type belongs to Family N:1",                    "implementation": "obligation_type.family_code FK" },
      { "rel": 5,  "semantic": "Archetype constrains Element N:M (Ma trận 1)",  "implementation": "foa_element (junction + requirement)" },
      { "rel": 6,  "semantic": "Type instantiates Archetype N:1",               "implementation": "obligation_type.archetype_code FK (MỚI)" },
      { "rel": 7,  "semantic": "ElementType compatible ElementType N:M (Ma trận 2)", "implementation": "constraint_matrix(kind=ELEMENTTYPE_X_ELEMENTTYPE) + matrix_cell" },
      { "rel": 8,  "semantic": "Lifecycle governs objects 1:N",                 "implementation": "lifecycle.governs + status enum trên các entity" },
      { "rel": 9,  "semantic": "Type × Block N:M (Ma trận 3)",                  "implementation": "constraint_matrix(kind=OBLIGATIONTYPE_X_BLOCK) + matrix_cell" },
      { "rel": 10, "semantic": "Block governed by Element N:1",                 "implementation": "block.governed_by_element_code FK nullable + governed_by_aspect" },
      { "rel": 11, "semantic": "Block contains Slot 1:N",                       "implementation": "answer_slot.block_id FK, PK(block_id,code)" },
      { "rel": 12, "semantic": "Slot binds Attribute N:1",                      "implementation": "answer_slot.attribute_code FK" },
      { "rel": 13, "semantic": "Attribute grouped in Group N:1",                "implementation": "attribute.group_code FK" },
      { "rel": 14, "semantic": "Attribute typed as DataType N:1",               "implementation": "attribute.data_type_code FK (data_type là bảng, MỚI)" },
      { "rel": 15, "semantic": "Group owned by Domain N:1",                     "implementation": "attribute_group.domain_code FK (MỚI)" },
