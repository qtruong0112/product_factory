{
  "$schema": "https://productfactory.local/meta/relational-canonical-v2.json",
  "$id": "https://productfactory.local/schemas/product-factory-5.1-canonical-v3-semantic.json",
  "title": "Product Factory 5.1 — Canonical Schema v3 (Semantic-aligned, ERD-ready)",
  "description": "Hợp nhất 2 nguồn: (1) Product_Factory_Semantic_Objects.xlsx — 26 semantic objects / 4 tầng ngữ nghĩa / 29 relationships (nguồn chuẩn về NGỮ NGHĨA và CARDINALITY); (2) Product_Factory_5_1.html — mã nguồn app (nguồn chuẩn về CỘT, KIỂU DỮ LIỆU, INSTANCE). Mỗi entity gắn x-layer (I/II/III/IV) và x-semantic-object trỏ về object gốc trong xlsx. Mọi PK/FK/unique khai báo máy-đọc-được để gen ERD/DBML/DDL tự động.",

  "x-semantic-layers": {
    "I":   "Ontology nghĩa vụ (Obligation Ontology) — 6 objects",
    "II":  "Cấu hình (Configuration primitives) — 8 objects",
    "III": "Pipeline sản phẩm (Product pipeline) — 8 objects",
    "IV":  "Quản trị & Ràng buộc (Governance) — 4 objects"
  },

  "x-enums": {
    "entity_status":     ["draft", "review", "approved", "published", "retired"],
    "matrix_kind":       ["ARCHETYPE_X_ELEMENT", "ELEMENTTYPE_X_ELEMENTTYPE", "OBLIGATIONTYPE_X_BLOCK"],
    "matrix_verdict":    ["req", "pos", "na"],
    "block_usage":       ["active", "locked"],
    "constraint_kind":   ["regulatory", "range", "required", "dependency", "enum"],
    "scope_priority_note": "Ưu tiên giải quyết fragment: people(3) > place(2) > time(1) > default(0) — lưu trong bảng selector_scope.priority",
    "audience":          ["individual", "business"],
    "channel":           ["App", "Web", "PGD"],
    "ot_role":           ["Primary", "Support"],
    "foa_requirement":   ["required", "possible", "na"],
    "biz_group":         ["Khởi tạo", "Giá trị", "Kích hoạt", "Vận hành", "Thu hồi"],
    "version_entity_type": ["pattern", "template", "config"],
    "release_step_status": ["done", "current", "upcoming"],
    "release_role":      ["Product Owner", "Product Designer", "Product Designer / QA", "Checker / Approver", "Operations"],
    "customer_tier":     ["standard", "loyalty", "vip"]
  },

  "entities": {

    "obligation_element_type": {
      "x-layer": "I", "x-semantic-object": "#1 Obligation Element Type (OET)",
      "description": "Chiều phân loại ngữ nghĩa của nghĩa vụ. 6 chiều lõi (OET_NATURE…OET_TIME) + mở rộng OET_LIFECYCLE trong thư viện. OET_NATURE có is_identify=true — quyết định Family.",
      "primaryKey": ["code"],
      "columns": {
        "code":        { "type": "VARCHAR(30)", "nullable": false },
        "name":        { "type": "VARCHAR(80)", "nullable": false },
        "short_name":  { "type": "VARCHAR(40)", "nullable": true },
        "description": { "type": "TEXT", "nullable": true },
        "is_identify": { "type": "BOOLEAN", "nullable": false, "default": false }
      }
    },

    "obligation_element": {
      "x-layer": "I", "x-semantic-object": "#2 Obligation Element",
      "description": "Giá trị nguyên tử — 'gen' ngữ nghĩa để lắp thành Obligation Type. App: 17 element, thư viện đầy đủ: 47. Rel #1: ElementType 1:N Element.",
      "primaryKey": ["code"],
      "columns": {
        "code":              { "type": "VARCHAR(60)", "nullable": false },
        "name":              { "type": "VARCHAR(160)", "nullable": false },
        "element_type_code": { "type": "VARCHAR(30)", "nullable": false }
      },
      "foreignKeys": [
        { "columns": ["element_type_code"], "references": { "entity": "obligation_element_type", "columns": ["code"] } }
      ]
    },

    "financial_obligation_archetype": {
      "x-layer": "I", "x-semantic-object": "#3 Financial Obligation Archetype",
      "description": "Khuôn nghĩa vụ gốc — mẫu trừu tượng cao nhất (Term Loan / Revolving / Conditional). Quy định Element nào Required/Possible qua Ma trận 1 (materialize ở foa_element).",
      "primaryKey": ["code"],
      "columns": {
        "code":            { "type": "VARCHAR(30)", "nullable": false },
        "name":            { "type": "VARCHAR(80)", "nullable": false },
        "nature":          { "type": "VARCHAR(160)", "nullable": true },
        "nature_desc":     { "type": "TEXT", "nullable": true },
        "value_structure": { "type": "VARCHAR(160)", "nullable": true },
        "value_desc":      { "type": "TEXT", "nullable": true }
      }
    },

    "foa_element": {
      "x-layer": "I", "x-semantic-object": "#23 Ma trận 1 (Archetype × Element) — materialized",
      "description": "Rel #5: Archetype constrains Element N:M kèm mức Required/Possible/N.A — ma trận gốc suy diễn Family & hợp lệ hóa Pattern/Intent.",
      "primaryKey": ["archetype_code", "element_code"],
      "columns": {
        "archetype_code": { "type": "VARCHAR(30)", "nullable": false },
        "element_code":   { "type": "VARCHAR(60)", "nullable": false },
        "requirement":    { "type": "VARCHAR(10)", "nullable": false, "enum": "foa_requirement" }
      },
      "foreignKeys": [
        { "columns": ["archetype_code"], "references": { "entity": "financial_obligation_archetype", "columns": ["code"] }, "onDelete": "CASCADE" },
        { "columns": ["element_code"],   "references": { "entity": "obligation_element", "columns": ["code"] } }
      ]
    },

    "obligation_family": {
      "x-layer": "I", "x-semantic-object": "#4 Obligation Family",
      "description": "Họ nghĩa vụ. Rel #3: Nature định danh Family 1:1 → FK identified_by_nature_code UNIQUE (mỗi Nature định danh đúng 1 Family và ngược lại).",
      "primaryKey": ["code"],
      "columns": {
        "code":                      { "type": "VARCHAR(30)", "nullable": false },
        "name":                      { "type": "VARCHAR(80)", "nullable": false },
        "identified_by_nature_code": { "type": "VARCHAR(60)", "nullable": false, "comment": "Element thuộc OET_NATURE (is_identify)" }
      },
      "uniques": [["identified_by_nature_code"]],
      "foreignKeys": [
        { "columns": ["identified_by_nature_code"], "references": { "entity": "obligation_element", "columns": ["code"] } }
      ]
    },

    "obligation_type": {
      "x-layer": "I", "x-semantic-object": "#5 Obligation Type",
      "description": "Loại nghĩa vụ chuẩn hóa = tổ hợp đủ 6 Element (mỗi OET đúng 1, materialize ở obligation_type_composition). Nút trung tâm nối ontology với Block. Rel #4: N Type thuộc 1 Family. Rel #6 (MỚI so với v2): mỗi Type hiện thực hóa 1 Archetype.",
      "primaryKey": ["code"],
      "columns": {
        "code":           { "type": "VARCHAR(60)", "nullable": false },
        "name":           { "type": "VARCHAR(160)", "nullable": false },
        "family_code":    { "type": "VARCHAR(30)", "nullable": false },
        "archetype_code": { "type": "VARCHAR(30)", "nullable": false },
        "status":         { "type": "VARCHAR(12)", "nullable": false, "enum": "entity_status" }
      },
      "foreignKeys": [
        { "columns": ["family_code"],    "references": { "entity": "obligation_family", "columns": ["code"] } },
        { "columns": ["archetype_code"], "references": { "entity": "financial_obligation_archetype", "columns": ["code"] } }
      ]
    },

    "obligation_type_composition": {
      "x-layer": "I", "x-semantic-object": "#2↔#5 (rel #2 composes)",
      "description": "Rel #2: N Element cấu thành 1 Type; PK ghép (type, element_type) ép ràng buộc 'mỗi OET chọn đúng 1 Element' (trường comp trong HTML).",
      "primaryKey": ["obligation_type_code", "element_type_code"],
      "columns": {
        "obligation_type_code": { "type": "VARCHAR(60)", "nullable": false },
        "element_type_code":    { "type": "VARCHAR(30)", "nullable": false },
        "element_code":         { "type": "VARCHAR(60)", "nullable": false }
      },
      "foreignKeys": [
        { "columns": ["obligation_type_code"], "references": { "entity": "obligation_type", "columns": ["code"] }, "onDelete": "CASCADE" },
        { "columns": ["element_type_code"],    "references": { "entity": "obligation_element_type", "columns": ["code"] } },
        { "columns": ["element_code"],         "references": { "entity": "obligation_element", "columns": ["code"] } }
      ]
    },

    "lifecycle": {
      "x-layer": "I", "x-semantic-object": "#6 Lifecycle & State Machine",
      "description": "Rel #8: mỗi Lifecycle chi phối 1 loại đối tượng (Term Loan 7 state, Facility 6, Product Variant 5, Pattern 5, Config maker–checker 6, Domain 4).",
      "primaryKey": ["code"],
      "columns": {
        "code":       { "type": "VARCHAR(40)", "nullable": false },
        "name":       { "type": "VARCHAR(160)", "nullable": false },
        "governs":    { "type": "VARCHAR(80)", "nullable": false, "comment": "Loại đối tượng được chi phối" },
        "status":     { "type": "VARCHAR(12)", "nullable": false, "enum": "entity_status" }
      }
    },

    "lifecycle_state": {
      "x-layer": "I", "x-semantic-object": "#6 Lifecycle & State Machine",
      "description": "State có thứ tự của lifecycle (Draft, Active, Overdue, Closed…).",
      "primaryKey": ["lifecycle_code", "sort_order"],
      "columns": {
        "lifecycle_code": { "type": "VARCHAR(40)", "nullable": false },
        "sort_order":     { "type": "SMALLINT", "nullable": false },
        "name":           { "type": "VARCHAR(60)", "nullable": false }
      },
      "foreignKeys": [
        { "columns": ["lifecycle_code"], "references": { "entity": "lifecycle", "columns": ["code"] }, "onDelete": "CASCADE" }
      ]
    },

    "domain": {
      "x-layer": "II", "x-semantic-object": "#14 Domain",
      "description": "Miền dữ liệu — ranh giới sở hữu ngữ nghĩa (DOM_PRODUCT 142 thực thể, DOM_OBLIGATION 98, DOM_PARTY 37, DOM_COLLATERAL 54, DOM_PRICING 29).",
      "primaryKey": ["code"],
      "columns": {
        "code":         { "type": "VARCHAR(40)", "nullable": false },
        "name":         { "type": "VARCHAR(120)", "nullable": false },
        "description":  { "type": "TEXT", "nullable": true },
        "entity_count": { "type": "INTEGER", "nullable": true },
        "status":       { "type": "VARCHAR(12)", "nullable": false, "enum": "entity_status" }
      }
    },

    "data_type": {
      "x-layer": "II", "x-semantic-object": "#13 Data Type",
      "description": "Kiểu dữ liệu của Attribute — object riêng theo semantic sheet (không còn là enum như v2): DT_MONEY, DT_PERCENT, DT_INT, DT_ENUM, DT_RANGE, DT_BOOL, DT_FORMULA.",
      "primaryKey": ["code"],
      "columns": {
        "code": { "type": "VARCHAR(20)", "nullable": false },
        "name": { "type": "VARCHAR(60)", "nullable": false }
      }
    },

    "attribute_group": {
      "x-layer": "II", "x-semantic-object": "#12 Attribute Group",
      "description": "Nhóm nghiệp vụ của Attribute (GRP_PRICING 11, GRP_LIMIT 7, GRP_COLLATERAL 9, GRP_REPAYMENT 8, GRP_PARTY 10, GRP_PENALTY 6). Rel #15 (MỚI so với v2): Group thuộc Domain N:1 (GRP_PRICING → DOM_PRICING, GRP_LIMIT → DOM_PRODUCT…).",
      "primaryKey": ["code"],
      "columns": {
        "code":        { "type": "VARCHAR(40)", "nullable": false },
        "name":        { "type": "VARCHAR(120)", "nullable": false },
        "domain_code": { "type": "VARCHAR(40)", "nullable": false }
      },
      "foreignKeys": [
        { "columns": ["domain_code"], "references": { "entity": "domain", "columns": ["code"] } }
      ]
    },

    "attribute": {
      "x-layer": "II", "x-semantic-object": "#9 Attribute",
      "description": "Thuộc tính kinh doanh trong Từ điển thuộc tính (64 attr: base_rate, ltv, limit_amount…), tái sử dụng qua nhiều Block/Template. Rel #13 grouped in, rel #14 typed as. Ràng buộc chi tiết tách sang attribute_constraint (rel #17).",
      "primaryKey": ["code"],
      "columns": {
        "code":           { "type": "VARCHAR(60)", "nullable": false },
        "name":           { "type": "VARCHAR(160)", "nullable": false },
        "group_code":     { "type": "VARCHAR(40)", "nullable": false },
        "data_type_code": { "type": "VARCHAR(20)", "nullable": false },
        "is_required":    { "type": "BOOLEAN", "nullable": false, "default": false },
        "is_unique":      { "type": "BOOLEAN", "nullable": false, "default": false },
        "is_nullable":    { "type": "BOOLEAN", "nullable": false, "default": true },
        "default_value":  { "type": "VARCHAR(255)", "nullable": true },
        "unit":           { "type": "VARCHAR(40)", "nullable": true }
      },
      "foreignKeys": [
        { "columns": ["group_code"],     "references": { "entity": "attribute_group", "columns": ["code"] } },
        { "columns": ["data_type_code"], "references": { "entity": "data_type", "columns": ["code"] } }
      ]
    },

    "attribute_constraint": {
      "x-layer": "II", "x-semantic-object": "#11 Constraint",
      "description": "Rel #17: 1 Attribute chịu N Constraint. 5 loại: regulatory (trần NHNN ≤1,65%/tháng), range (min/max/step), required, dependency (liên thuộc tính — base_rate phụ thuộc rate_type; limit ≤ LTV × giá trị TS; LTV chỉ khi Recovery=ASSET_PLEDGE), enum. Dependency dùng FK depends_on_attribute_code.",
      "primaryKey": ["id"],
      "columns": {
        "id":                        { "type": "BIGINT", "nullable": false, "autoIncrement": true },
        "attribute_code":            { "type": "VARCHAR(60)", "nullable": false },
        "kind":                      { "type": "VARCHAR(12)", "nullable": false, "enum": "constraint_kind" },
        "min_value":                 { "type": "DECIMAL(18,4)", "nullable": true },
        "max_value":                 { "type": "DECIMAL(18,4)", "nullable": true },
        "step_value":                { "type": "DECIMAL(18,4)", "nullable": true },
        "expression":                { "type": "VARCHAR(255)", "nullable": true, "comment": "Biểu thức ràng buộc, vd 'limit <= ltv * asset_value'" },
        "depends_on_attribute_code": { "type": "VARCHAR(60)", "nullable": true, "comment": "Attribute bị phụ thuộc (constraint kind=dependency)" },
        "message":                   { "type": "VARCHAR(255)", "nullable": true }
      },
      "foreignKeys": [
        { "columns": ["attribute_code"],            "references": { "entity": "attribute", "columns": ["code"] }, "onDelete": "CASCADE" },
        { "columns": ["depends_on_attribute_code"], "references": { "entity": "attribute", "columns": ["code"] } }
      ]
    },

    "attribute_enum_value": {
      "x-layer": "II", "x-semantic-object": "#11 Constraint (kind=enum)",
      "description": "Giá trị enum của attribute kiểu DT_ENUM (vd asset_type: Xe máy / Ô tô / Vàng).",
      "primaryKey": ["attribute_code", "sort_order"],
      "columns": {
        "attribute_code": { "type": "VARCHAR(60)", "nullable": false },
        "sort_order":     { "type": "SMALLINT", "nullable": false },
        "value":          { "type": "VARCHAR(160)", "nullable": false }
      },
      "foreignKeys": [
        { "columns": ["attribute_code"], "references": { "entity": "attribute", "columns": ["code"] }, "onDelete": "CASCADE" }
      ]
    },

    "block": {
      "x-layer": "II", "x-semantic-object": "#7 Block",
      "description": "Khối cấu hình nghiệp vụ, 5 nhóm (Khởi tạo/Giá trị/Kích hoạt/Vận hành/Thu hồi). App: 12 block, thư viện: 26. Rel #10: mỗi Block governance bởi 1 Element (BLK_INTEREST↔TERM_LOAN_OBLIGATION, BLK_COLLATERAL↔ASSET_PLEDGE…) — FK nullable vì một số block neo vào 'khía cạnh' chưa mã hóa thành element (Eligibility, Obligor Party).",
      "primaryKey": ["id"],
      "columns": {
        "id":                        { "type": "VARCHAR(40)", "nullable": false },
        "code":                      { "type": "VARCHAR(60)", "nullable": false },
        "name":                      { "type": "VARCHAR(160)", "nullable": false },
        "biz_group":                 { "type": "VARCHAR(20)", "nullable": false, "enum": "biz_group" },
        "governed_by_element_code":  { "type": "VARCHAR(60)", "nullable": true },
        "governed_by_aspect":        { "type": "VARCHAR(80)", "nullable": true, "comment": "Khía cạnh chi phối khi không phải element (Eligibility, Obligor Party, PENALTY…)" },
        "status":                    { "type": "VARCHAR(12)", "nullable": false, "enum": "entity_status" }
      },
      "uniques": [["code"]],
      "foreignKeys": [
        { "columns": ["governed_by_element_code"], "references": { "entity": "obligation_element", "columns": ["code"] } }
      ]
    },

    "answer_slot": {
      "x-layer": "II", "x-semantic-object": "#8 Answer Slot",
      "description": "Ô khai báo trong Block — nơi 1 Attribute được 'cắm' vào kèm cờ bắt buộc, default, rule (~30 slot). Rel #11: Block 1:N Slot. Rel #12: Slot binds Attribute N:1 (whereUsed).",
      "primaryKey": ["block_id", "code"],
      "columns": {
        "block_id":       { "type": "VARCHAR(40)", "nullable": false },
        "code":           { "type": "VARCHAR(60)", "nullable": false },
        "name":           { "type": "VARCHAR(160)", "nullable": false },
        "attribute_code": { "type": "VARCHAR(60)", "nullable": false },
        "is_required":    { "type": "BOOLEAN", "nullable": false, "default": false },
        "default_value":  { "type": "VARCHAR(255)", "nullable": true },
        "rule_text":      { "type": "VARCHAR(255)", "nullable": true }
      },
      "foreignKeys": [
        { "columns": ["block_id"],       "references": { "entity": "block", "columns": ["id"] }, "onDelete": "CASCADE" },
        { "columns": ["attribute_code"], "references": { "entity": "attribute", "columns": ["code"] } }
      ]
    },

    "selector_scope": {
      "x-layer": "II", "x-semantic-object": "#10 Fragment & Scope",
      "description": "Loại phạm vi áp dụng của Fragment, kèm priority giải quyết xung đột: default(0) < time(1) < place(2) < people(3).",
      "primaryKey": ["code"],
      "columns": {
        "code":     { "type": "VARCHAR(10)", "nullable": false, "comment": "default / time / place / people" },
        "name":     { "type": "VARCHAR(60)", "nullable": false },
        "priority": { "type": "SMALLINT", "nullable": false }
      }
    },

    "fragment": {
      "x-layer": "II", "x-semantic-object": "#10 Fragment & Scope",
      "description": "Giá trị của Attribute theo phạm vi, trong bối cảnh 1 Config (rel #16 + rel #24: Config gán giá trị Attribute vào slot của Template qua Fragment+Scope). Vd base_rate: 1,5% default · 1,0% Loyalty · 1,4% HCM/HN · 0,9% KM Tết. Bất biến nghiệp vụ: mỗi (config, slot) phải có ≥1 fragment scope=default.",
      "primaryKey": ["id"],
      "columns": {
        "id":             { "type": "BIGINT", "nullable": false, "autoIncrement": true },
        "config_code":    { "type": "VARCHAR(20)", "nullable": false },
        "block_id":       { "type": "VARCHAR(40)", "nullable": false },
        "slot_code":      { "type": "VARCHAR(60)", "nullable": false },
        "scope_code":     { "type": "VARCHAR(10)", "nullable": false },
        "scope_value":    { "type": "VARCHAR(120)", "nullable": true, "comment": "NULL với scope default; 'Loyalty'/'HCM, HN'/'KM Tết'…" },
        "value":          { "type": "VARCHAR(255)", "nullable": false },
        "is_warning":     { "type": "BOOLEAN", "nullable": false, "default": false },
        "validation_msg": { "type": "VARCHAR(255)", "nullable": true }
      },
      "uniques": [["config_code", "block_id", "slot_code", "scope_code", "scope_value"]],
      "foreignKeys": [
        { "columns": ["config_code"],            "references": { "entity": "product_config", "columns": ["code"] }, "onDelete": "CASCADE" },
        { "columns": ["block_id", "slot_code"],  "references": { "entity": "answer_slot", "columns": ["block_id", "code"] } },
        { "columns": ["scope_code"],             "references": { "entity": "selector_scope", "columns": ["code"] } }
      ]
    },

    "business_intent": {
      "x-layer": "III", "x-semantic-object": "#15 Business Intent",
      "description": "Định hướng kinh doanh nguồn (7 intent): mục tiêu, KPI, owner, kỳ áp dụng. Rel #18: 1 BI dẫn xuất N Product Intent.",
      "primaryKey": ["id"],
      "columns": {
        "id":        { "type": "BIGINT", "nullable": false, "autoIncrement": true },
        "name":      { "type": "VARCHAR(200)", "nullable": false },
        "owner":     { "type": "VARCHAR(120)", "nullable": false },
        "period":    { "type": "VARCHAR(60)", "nullable": false },
        "objective": { "type": "TEXT", "nullable": true },
        "status":    { "type": "VARCHAR(12)", "nullable": false, "enum": "entity_status" }
      }
    },

    "business_intent_kpi": {
      "x-layer": "III", "x-semantic-object": "#15 Business Intent",
      "description": "KPI của Business Intent (Dư nợ 1.200 tỷ, 48.000 HĐ, NPL ≤3%…).",
      "primaryKey": ["business_intent_id", "sort_order"],
      "columns": {
        "business_intent_id": { "type": "BIGINT", "nullable": false },
        "sort_order":         { "type": "SMALLINT", "nullable": false },
        "metric":             { "type": "VARCHAR(160)", "nullable": false },
        "target":             { "type": "VARCHAR(80)", "nullable": false },
        "unit":               { "type": "VARCHAR(40)", "nullable": true }
      },
      "foreignKeys": [
        { "columns": ["business_intent_id"], "references": { "entity": "business_intent", "columns": ["id"] }, "onDelete": "CASCADE" }
      ]
    },

    "customer_segment": {
      "x-layer": "III", "x-semantic-object": "#22 Customer Segment / Audience",
      "description": "Đối tượng KH mục tiêu — object riêng theo semantic sheet (MỚI so với v2): KH cá nhân (CMND/CCCD · Giấy nhận nợ) / KH doanh nghiệp (ĐKKD · HĐ tín dụng DN), kèm tier Standard/Loyalty/VIP.",
      "primaryKey": ["code"],
      "columns": {
        "code":              { "type": "VARCHAR(40)", "nullable": false },
        "name":              { "type": "VARCHAR(160)", "nullable": false },
        "audience":          { "type": "VARCHAR(12)", "nullable": false, "enum": "audience" },
